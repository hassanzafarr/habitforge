    "@types/marked": "^5.0.2",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.0.24",
    "lucide-react": "^0.363.0",
    "marked": "^18.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.3",
    "sonner": "^1.4.41",
    "tailwind-merge": "^2.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
